<Page x:Class="Mercedes.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Mercedes.Pages"
      xmlns:converters="clr-namespace:Mercedes.Converters"
      xmlns:enums="clr-namespace:Mercedes.Data.Enums;assembly=Mercedes.Data"
      xmlns:services="clr-namespace:Mercedes.Services"
      xmlns:ext="clr-namespace:Mercedes.Extensions"
      xmlns:ui="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1200"
      Title="Админ-панель"
      FontFamily="Segoe UI Variable, Segoe UI"
      Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
        <converters:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter"/>
        <converters:RoleToVisibilityConverter x:Key="RoleToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <SolidColorBrush x:Key="AccentBrush" Color="#00A6FF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF4444"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#28A745"/>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="RowHeight" Value="45"/>
            <Setter Property="AlternatingRowBackground" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,12,0,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="DataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2,0"/>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0082CC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Cursor="Hand" MouseLeftButtonDown="BackButton_Click">
                    <TextBlock Text="←" FontSize="20" Foreground="White" Margin="0,0,6,0"/>
                    <TextBlock Text="На главную" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Orientation="Horizontal">
                    <Viewbox Stretch="Uniform" MaxWidth="150">
                        <TextBlock Text="MERCEDES" FontWeight="Bold" Foreground="#00A6FF"/>
                    </Viewbox>
                    <TextBlock Text=" | Админ" FontSize="18" FontWeight="Bold" Foreground="White" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock x:Name="AdminNameText" Text="" Foreground="White" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Border Background="#FF4444" CornerRadius="16" Padding="12,12" Cursor="Hand" MouseLeftButtonDown="LogoutButton_Click" Visibility="{Binding Source={ext:SessionService}, Path=IsLoggedIn, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Выйти" Foreground="White" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Табы с данными -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="16,12">
            
            <!-- Пользователи -->
            <TabItem Header="👥 Пользователи" Style="{StaticResource TabItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Все пользователи системы" FontSize="20" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="📊 Excel" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Click="ExportUsers_Click"/>
                    </Grid>
                    
                    <DataGrid x:Name="UsersDataGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.5*" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="*" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="80" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="80" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTemplateColumn Header="Действия" Width="100" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="🗑️" Style="{StaticResource ActionButtonStyle}" Background="#DC3545" Foreground="White" Tag="{Binding Id}" Click="DeleteUser_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <Button Grid.Row="2" Content="💾 Сохранить изменения" Style="{StaticResource AccentButtonStyle}" Margin="0,12,0,0" Padding="20,10" FontSize="14" Click="SaveUsers_Click"/>
                </Grid>
            </TabItem>

            <!-- Автомобили -->
            <TabItem Header="🚗 Автомобили" Style="{StaticResource TabItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Каталог автомобилей" FontSize="20" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="📊 Excel" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Margin="0,0,8,0" Click="ExportCars_Click"/>
                        <Button Grid.Column="2" Content="➕ Добавить" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Click="AddCar_Click"/>
                    </Grid>
                    
                    <DataGrid x:Name="CarsDataGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Модель" Binding="{Binding Model}" Width="1.5*" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type, Converter={StaticResource EnumToDescriptionConverter}}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Класс" Binding="{Binding Class}" Width="70" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="60" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price}" Width="*" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="VIN" Binding="{Binding VinNumber}" Width="1.2*" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridCheckBoxColumn Header="Наличие" Binding="{Binding IsAviable}" Width="80" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTemplateColumn Header="Действия" Width="100" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="🗑️" Style="{StaticResource ActionButtonStyle}" Background="#DC3545" Foreground="White" Tag="{Binding Id}" Click="DeleteCar_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    
                    <Button Grid.Row="2" Content="💾 Сохранить изменения" Style="{StaticResource AccentButtonStyle}" Margin="0,12,0,0" Padding="20,10" FontSize="14" Click="SaveCars_Click"/>
                </Grid>
            </TabItem>

            <!-- Записи на тест-драйв -->
            <TabItem Header="📅 Тест-драйвы" Style="{StaticResource TabItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Все записи на тест-драйв" FontSize="20" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="📊 Excel" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Click="ExportTestDrives_Click"/>
                    </Grid>
                    
                    <DataGrid x:Name="TestDrivesDataGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding User.FirstName}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding User.Email}" Width="1.5*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Автомобиль" Binding="{Binding Car.Model}" Width="1.5*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding RequestedDate, StringFormat=dd.MM.yyyy HH:mm}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTemplateColumn Header="Действия" Width="180" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="✅" Style="{StaticResource ActionButtonStyle}" Background="#28A745" Foreground="White" Tag="{Binding Id}" Click="ConfirmTestDrive_Click" Visibility="{Binding Status, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=Pending}"/>
                                            <Button Content="❌" Style="{StaticResource ActionButtonStyle}" Background="#DC3545" Foreground="White" Tag="{Binding Id}" Click="CancelTestDrive_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Продажи -->
            <TabItem Header="💰 Продажи" Style="{StaticResource TabItemStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Все продажи" FontSize="20" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="📊 Excel" Style="{StaticResource AccentButtonStyle}" Padding="12,6" Click="ExportSales_Click"/>
                    </Grid>
                    
                    <DataGrid x:Name="SalesDataGrid" Grid.Row="1" Style="{StaticResource DataGridStyle}" AutoGenerateColumns="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding User.FirstName}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding User.Email}" Width="1.5*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Автомобиль" Binding="{Binding Car.Model}" Width="1.5*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Цена" Binding="{Binding Price, StringFormat=N0 ₽}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*" IsReadOnly="True" HeaderStyle="{StaticResource DataGridHeaderStyle}"/>
                            <DataGridTemplateColumn Header="Действия" Width="180" HeaderStyle="{StaticResource DataGridHeaderStyle}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button Content="✅" Style="{StaticResource ActionButtonStyle}" Background="#28A745" Foreground="White" Tag="{Binding Id}" Click="CompleteSale_Click" Visibility="{Binding Status, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=Pending}"/>
                                            <Button Content="❌" Style="{StaticResource ActionButtonStyle}" Background="#DC3545" Foreground="White" Tag="{Binding Id}" Click="CancelSale_Click"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- О приложении -->
            <TabItem Header="ℹ️ О приложении" Style="{StaticResource TabItemStyle}">
                <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="32">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Viewbox Width="120" Height="40" Margin="0,0,0,24">
                            <TextBlock Text="MERCEDES" FontSize="32" FontWeight="Bold" Foreground="#00A6FF"/>
                        </Viewbox>
                        
                        <TextBlock Text="Автосалон Mercedes" FontSize="24" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        
                        <TextBlock Text="Версия 1.0.0" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        
                        <TextBlock Text="© 2024 Mercedes-Benz" FontSize="12" Foreground="#999" HorizontalAlignment="Center"/>
                        
                        <Border Background="#F8F8F8" CornerRadius="8" Padding="20" Margin="0,24,0,0">
                            <StackPanel>
                                <TextBlock Text="Функционал:" FontSize="16" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                                <TextBlock Text="• Каталог автомобилей Mercedes-Benz" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Избранное и покупки" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Запись на тест-драйв" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Админ-панель" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                                <TextBlock Text="• Экспорт данных в Excel" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- Статистика -->
            <TabItem Header="📊 Статистика" Style="{StaticResource TabItemStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Статистика продаж" FontSize="20" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Продажи по месяцам -->
                            <Border Grid.Column="0" Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16" Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="Продажи по месяцам" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                    <oxy:PlotView x:Name="SalesByMonthPlot" Height="200"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Автомобили по типу -->
                            <Border Grid.Column="1" Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16" Margin="8,0,0,8">
                                <StackPanel>
                                    <TextBlock Text="Автомобили по типу кузова" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                    <oxy:PlotView x:Name="CarsByTypePlot" Height="200"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Статус тест-драйвов -->
                            <Border Grid.Column="0" Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16" Margin="0,8,8,0">
                                <StackPanel>
                                    <TextBlock Text="Статус тест-драйвов" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                    <oxy:PlotView x:Name="TestDrivesStatusPlot" Height="200"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Общая статистика -->
                            <Border Grid.Column="1" Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="16" Margin="8,8,0,0">
                                <StackPanel>
                                    <TextBlock Text="Общая статистика" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        
                                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,8">
                                            <TextBlock Text="Всего пользователей" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TotalUsersText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#00A6FF"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,8">
                                            <TextBlock Text="Всего автомобилей" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TotalCarsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#00A6FF"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,0,8">
                                            <TextBlock Text="Продано автомобилей" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="SoldCarsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#28A745"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,0,8">
                                            <TextBlock Text="Записей на тест-драйв" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TotalTestDrivesText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#FFA500"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="0" Grid.Row="2" Margin="0,0,0,8">
                                            <TextBlock Text="Выручка" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="TotalRevenueText" Text="0 BYN" FontSize="24" FontWeight="Bold" Foreground="#28A745"/>
                                        </StackPanel>
                                        
                                        <StackPanel Grid.Column="1" Grid.Row="2" Margin="0,0,0,8">
                                            <TextBlock Text="В наличии" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock x:Name="AvailableCarsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#00A6FF"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Page>