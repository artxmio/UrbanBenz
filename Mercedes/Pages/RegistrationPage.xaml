<Page x:Class="Mercedes.Pages.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Mercedes.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1200"
      Title="Регистрация"
      FontFamily="Segoe UI Variable, Segoe UI">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#00A6FF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="15" ShadowDepth="2" Color="#20000000"/>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Stretch="Uniform" HorizontalAlignment="Left" MaxWidth="200">
                    <TextBlock Text="MERCEDES" FontWeight="Bold" Foreground="#00A6FF"/>
                </Viewbox>

                <Button Grid.Column="2" 
                        Content="← Назад" 
                        Background="Transparent" 
                        Foreground="White" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Padding="12,6"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Форма регистрации -->
        <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="16" 
                    Padding="32,28" 
                    MaxWidth="480"
                    MinWidth="320"
                    Effect="{StaticResource DropShadowEffect}">
                <StackPanel>
                    <TextBlock Text="Создание аккаунта" 
                               FontSize="24" 
                               FontWeight="Light" 
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,6"/>

                    <TextBlock Text="Заполните форму для регистрации" 
                               FontSize="13" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <!-- Имя и Фамилия -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Имя" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                            <TextBox x:Name="FirstNameTextBox" 
                                     Height="40" 
                                     Padding="8"
                                     BorderThickness="1"
                                     FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Фамилия" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                            <TextBox x:Name="LastNameTextBox" 
                                     Height="40" 
                                     Padding="8"
                                     BorderThickness="1"
                                     FontSize="14"/>
                        </StackPanel>
                    </Grid>

                    <!-- Email -->
                    <TextBlock Text="Email" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="EmailTextBox" 
                             Height="40" 
                             Padding="8"
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,12"/>

                    <!-- Телефон -->
                    <TextBlock Text="Телефон (необязательно)" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="PhoneTextBox" 
                             Height="40" 
                             Padding="8"
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,12"/>

                    <!-- Пароль и Подтверждение -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,8,0">
                            <TextBlock Text="Пароль" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="PasswordBox" 
                                         Height="40" 
                                         Padding="8"
                                         BorderThickness="1"
                                         FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Подтвердите" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,5"/>
                            <PasswordBox x:Name="ConfirmPasswordBox" 
                                         Height="40" 
                                         Padding="8"
                                         BorderThickness="1"
                                         FontSize="14"/>
                        </StackPanel>
                    </Grid>

                    <!-- Кнопка регистрации -->
                    <Button Content="Зарегистрироваться" 
                            Height="44" 
                            Background="{StaticResource AccentBrush}" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="15" 
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="RegisterButton_Click"/>

                    <!-- Ссылка на вход -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Margin="0,16,0,0">
                        <TextBlock Text="Уже есть аккаунт? " 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBlock Text="Войти" 
                                   Foreground="{StaticResource AccentBrush}" 
                                   Cursor="Hand"
                                   FontSize="13"
                                   MouseLeftButtonDown="LoginLink_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="16,12" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="Mercedes-Benz — лучшее для лучших" 
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"/>
        </Border>
    </Grid>
</Page>