<Page x:Class="Mercedes.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Mercedes.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1200"
      Title="Вход"
      FontFamily="Segoe UI Variable, Segoe UI">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#00A6FF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="15" ShadowDepth="2" Color="#20000000"/>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="URBAN" FontSize="32" FontWeight="Bold" Foreground="#00A6FF"/>
                    <TextBlock Text="BENZ" FontSize="32" FontWeight="Bold" Foreground="White" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" 
                        Content="← Назад" 
                        Background="Transparent" 
                        Foreground="White" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Форма входа -->
        <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="16" 
                    Padding="48,40" 
                    Width="420"
                    Effect="{StaticResource DropShadowEffect}">
                <StackPanel>
                    <TextBlock Text="С возвращением" 
                               FontSize="28" 
                               FontWeight="Light" 
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Войдите в свой аккаунт" 
                               FontSize="14" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,32"/>

                    <!-- Email -->
                    <TextBlock Text="Email" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="EmailTextBox" 
                             Height="44" 
                             Padding="12,0"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,16"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox" 
                                 Height="44" 
                                 Padding="12,0"
                                 BorderBrush="{StaticResource BorderBrush}" 
                                 BorderThickness="1"
                                 FontSize="14"
                                 Margin="0,0,0,24"/>

                    <!-- Запомнить и войти -->
                    <CheckBox x:Name="RememberCheckBox" 
                              Content="Запомнить меня" 
                              Margin="0,0,0,24"
                              Foreground="{StaticResource TextSecondaryBrush}"/>

                    <!-- Кнопка входа -->
                    <Button Content="Войти" 
                            Height="48" 
                            Background="{StaticResource AccentBrush}" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="16" 
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="LoginButton_Click"/>

                    <!-- Ссылка на регистрацию -->
                    <StackPanel Orientation="Horizontal" 
                                HorizontalAlignment="Center" 
                                Margin="0,20,0,0">
                        <TextBlock Text="Нет аккаунта? " 
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="Зарегистрироваться" 
                                   Foreground="{StaticResource AccentBrush}" 
                                   Cursor="Hand"
                                   MouseLeftButtonDown="RegisterLink_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="24,16" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="Mercedes-Benz — лучшее для лучших" 
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Page>