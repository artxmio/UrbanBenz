<Page x:Class="Mercedes.Pages.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Mercedes.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1200"
      Title="О приложении"
      FontFamily="Segoe UI Variable, Segoe UI">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#00A6FF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="15" ShadowDepth="2" Color="#20000000"/>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Cursor="Hand" MouseLeftButtonDown="BackButton_Click">
                    <TextBlock Text="←" FontSize="20" Foreground="White" Margin="0,0,6,0"/>
                    <TextBlock Text="Назад" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="О приложении" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24">
            <Border Background="{StaticResource CardBackgroundBrush}" CornerRadius="16" Padding="32" MaxWidth="600" HorizontalAlignment="Center" Effect="{StaticResource DropShadowEffect}">
                <StackPanel HorizontalAlignment="Center">
                    <Viewbox Width="160" Height="50" Margin="0,0,0,24">
                        <TextBlock Text="MERCEDES" FontSize="40" FontWeight="Bold" Foreground="#00A6FF"/>
                    </Viewbox>
                    
                    <TextBlock Text="Автосалон Mercedes" FontSize="24" FontWeight="Light" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    
                    
                    <TextBlock Text="Курсовой проект Mercedes. Разработчик: Веселуха Дмитрий Вячеславович 81ТП." 
                               FontSize="14" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"/>
                    
                    
                    <!-- Функционал -->
                    <Border Background="#F8F8F8" CornerRadius="12" Padding="20" Width="400">
                        <StackPanel>
                            <TextBlock Text="Возможности приложения" FontSize="16" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16" HorizontalAlignment="Center"/>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="🚗" FontSize="20" Margin="0,0,0,4"/>
                                <TextBlock Text="Каталог автомобилей" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                                <TextBlock Text="Просмотр и выбор автомобилей из наличия" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="❤️" FontSize="20" Margin="0,0,0,4"/>
                                <TextBlock Text="Избранное" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                                <TextBlock Text="Сохраняйте понравившиеся автомобили" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="📅" FontSize="20" Margin="0,0,0,4"/>
                                <TextBlock Text="Тест-драйв" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                                <TextBlock Text="Запись на тест-драйв онлайн" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="💰" FontSize="20" Margin="0,0,0,4"/>
                                <TextBlock Text="Покупка" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                                <TextBlock Text="Оформление покупки автомобиля" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            
                            <StackPanel>
                                <TextBlock Text="👤" FontSize="20" Margin="0,0,0,4"/>
                                <TextBlock Text="Личный кабинет" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Medium"/>
                                <TextBlock Text="История покупок и профиль" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="16,12" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="Mercedes-Benz — лучшее для лучших" Foreground="#666" HorizontalAlignment="Center" FontSize="12"/>
        </Border>
    </Grid>
</Page>