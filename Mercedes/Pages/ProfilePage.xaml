<Page x:Class="Mercedes.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Mercedes.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1200"
      Title="Профиль"
      FontFamily="Segoe UI Variable, Segoe UI"
      Loaded="Page_Loaded">

    <Page.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#00A6FF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
        <DropShadowEffect x:Key="DropShadowEffect" BlurRadius="15" ShadowDepth="2" Color="#20000000"/>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="24,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="URBAN" FontSize="32" FontWeight="Bold" Foreground="#00A6FF"/>
                    <TextBlock Text="BENZ" FontSize="32" FontWeight="Bold" Foreground="White" Margin="8,0,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" 
                        Content="← На главную" 
                        Background="Transparent" 
                        Foreground="White" 
                        BorderThickness="0" 
                        Cursor="Hand"
                        Click="BackButton_Click"/>
            </Grid>
        </Border>

        <!-- Профиль -->
        <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Background="{StaticResource CardBackgroundBrush}" 
                    CornerRadius="16" 
                    Padding="48,40" 
                    Width="480"
                    Effect="{StaticResource DropShadowEffect}">
                <StackPanel>
                    <TextBlock Text="Мой профиль" 
                               FontSize="28" 
                               FontWeight="Light" 
                               Foreground="{StaticResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,32"/>

                    <!-- Имя -->
                    <TextBlock Text="Имя" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="FirstNameTextBox" 
                             Height="44" 
                             Padding="12,0"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,16"
                             IsReadOnly="True"/>

                    <!-- Фамилия -->
                    <TextBlock Text="Фамилия" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="LastNameTextBox" 
                             Height="44" 
                             Padding="12,0"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,16"
                             IsReadOnly="True"/>

                    <!-- Email -->
                    <TextBlock Text="Email" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="EmailTextBox" 
                             Height="44" 
                             Padding="12,0"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,16"
                             IsReadOnly="True"/>

                    <!-- Телефон -->
                    <TextBlock Text="Телефон" FontSize="14" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,6"/>
                    <TextBox x:Name="PhoneTextBox" 
                             Height="44" 
                             Padding="12,0"
                             BorderBrush="{StaticResource BorderBrush}" 
                             BorderThickness="1"
                             FontSize="14"
                             Margin="0,0,0,24"
                             IsReadOnly="True"/>

                    <!-- Кнопки редактирования -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="EditButton"
                                Grid.Column="0"
                                Content="✏️ Редактировать" 
                                Height="48" 
                                Background="{StaticResource AccentBrush}" 
                                Foreground="White" 
                                BorderThickness="0" 
                                FontSize="16" 
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Margin="0,0,8,0"
                                Click="EditButton_Click"/>
                        <Button x:Name="SaveButton"
                                Grid.Column="1"
                                Content="💾 Сохранить" 
                                Height="48" 
                                Background="#4CAF50" 
                                Foreground="White" 
                                BorderThickness="0" 
                                FontSize="16" 
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Margin="8,0,0,0"
                                Click="SaveButton_Click"
                                Visibility="Collapsed"/>
                    </Grid>

                    <!-- Кнопка выхода -->
                    <Button Content="🚪 Выйти из аккаунта" 
                            Height="48" 
                            Background="#FF4444" 
                            Foreground="White" 
                            BorderThickness="0" 
                            FontSize="16" 
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="LogoutButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" Padding="24,16" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="Mercedes-Benz — лучшее для лучших" 
                       Foreground="#666"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Page>