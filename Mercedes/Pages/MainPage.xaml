<Page x:Class="Mercedes.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Mercedes.Pages"
      xmlns:converters="clr-namespace:Mercedes.Converters"
      xmlns:enums="clr-namespace:Mercedes.Data.Enums;assembly=Mercedes.Data"
      xmlns:services="clr-namespace:Mercedes.Services"
      xmlns:ext="clr-namespace:Mercedes.Extensions"
      xmlns:ui="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1200"
      Title="Mercedes"
      FontFamily="Segoe UI Variable, Segoe UI"
      Loaded="Page_Loaded">

    <Page.Resources>
        <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
        <converters:BoolToStatusColorConverter x:Key="BoolToStatusColorConverter"/>
        <converters:PriceToRublesConverter x:Key="PriceToRublesConverter"/>
        <converters:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter"/>
        <converters:RoleToVisibilityConverter x:Key="RoleToVisibilityConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ImagePathConverter x:Key="ImagePathConverter"/>

        <SolidColorBrush x:Key="AccentBrush" Color="#00A6FF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#666666"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#FF4444"/>

        <Style x:Key="CarCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Color="#20000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0082CC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#F0F0F0"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1A" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Viewbox Grid.Column="0" Height="32" HorizontalAlignment="Left">
                    <TextBlock Text="MERCEDES" FontWeight="Bold" Foreground="#00A6FF"/>
                </Viewbox>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#2D2D2D" CornerRadius="16" Padding="12,6" Margin="0,0,6,0" Cursor="Hand" MouseLeftButtonDown="HelpButton_Click">
                        <TextBlock Text="❓" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#2D2D2D" CornerRadius="16" Padding="12,6" Margin="0,0,6,0" Cursor="Hand" MouseLeftButtonDown="AboutButton_Click">
                        <TextBlock Text="ℹ️" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#2D2D2D" CornerRadius="16" Padding="12,6" Margin="0,0,6,0" Cursor="Hand" MouseLeftButtonDown="AdminPanelButton_Click" Visibility="{Binding Source={ext:SessionService}, Path=CurrentUser, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=Admin}">
                        <TextBlock Text="⚙️" Foreground="White" FontSize="12"/>
                    </Border>
                    <Border Background="#2D2D2D" CornerRadius="16" Padding="12,6" Margin="0,0,6,0" Cursor="Hand" MouseLeftButtonDown="FavoritesButton_Click" Visibility="{Binding Source={ext:SessionService}, Path=CurrentUser, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=!Admin}">
                        <TextBlock Text="❤️" FontSize="12"/>
                    </Border>
                    <Border Background="#2D2D2D" CornerRadius="16" Padding="12,6" Margin="0,0,6,0" Cursor="Hand" MouseLeftButtonDown="UserInfoBorder_MouseLeftButtonDown" Visibility="{Binding Source={ext:SessionService}, Path=CurrentUser, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=!Admin}">
                        <TextBlock x:Name="UserNameText" Text="Войти" Foreground="White" FontSize="12"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="White" Padding="16" Margin="0,1,0,0">
            <StackPanel>
                <TextBlock Text="Поиск и фильтры" FontSize="18" FontWeight="Light" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="6" BorderBrush="#E0E0E0" BorderThickness="1" Margin="0,0,8,0">
                        <Grid>
                            <TextBlock Text="🔍" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="SearchBox" BorderThickness="0" Background="Transparent" Padding="36,8,8,8" TextChanged="SearchBox_TextChanged"/>
                        </Grid>
                    </Border>

                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="TypeFilter" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>
                    <ComboBox Grid.Row="0" Grid.Column="2" x:Name="ClassFilter" Margin="0,0,8,0" SelectionChanged="Filter_Changed"/>

                    <ComboBox Grid.Row="1" Grid.Column="0" x:Name="EngineFilter" Margin="0,8,8,0" SelectionChanged="Filter_Changed"/>
                    
                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Сбросить" Click="ResetFilters_Click" Background="#666" Foreground="White" BorderThickness="0" Padding="12,6" Margin="0,8,8,0" Cursor="Hand"/>
                        <Button Content="Обновить" Click="Refresh_Click" Background="#17A2B8" Foreground="White" BorderThickness="0" Padding="12,6" Margin="0,8,0,0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Cars -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="16,12">
            <ItemsControl x:Name="CarsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CarCardStyle}" MinWidth="280" MaxWidth="400" Tag="{Binding Id}" MouseLeftButtonDown="CarCard_Click" Cursor="Hand">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="140"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#2D2D2D" CornerRadius="8,8,0,0" Margin="-16,-16,-16,0">
                                    <Grid>
                                        <Image Stretch="Uniform" Margin="8" Source="{Binding Converter={StaticResource ImagePathConverter}}"/>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="{Binding IsAviable, Converter={StaticResource BoolToStatusColorConverter}}" CornerRadius="0,8,0,8" Padding="10,4" Margin="0">
                                            <TextBlock Text="{Binding IsAviable, Converter={StaticResource BoolToYesNoConverter}}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="0,10,0,6">
                                    <TextBlock Text="{Binding Model}" FontSize="18" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Price, Converter={StaticResource PriceToRublesConverter}}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>

                                <WrapPanel Grid.Row="2" Margin="0,0,0,10">
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock Text="{Binding Type, Converter={StaticResource EnumToDescriptionConverter}}" FontSize="11"/>
                                    </Border>
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock Text="{Binding Year}" FontSize="11"/>
                                    </Border>
                                    <Border Style="{StaticResource ChipStyle}">
                                        <TextBlock Text="{Binding Color}" FontSize="11"/>
                                    </Border>
                                </WrapPanel>

                                <Button Grid.Row="3" Content="❤️ В избранное" Style="{StaticResource AccentButtonStyle}" Click="AddToFavorites_Click" Tag="{Binding Id}" Background="#FF6B6B" Padding="12,6" FontSize="12" Visibility="{Binding Source={ext:SessionService}, Path=CurrentUser, Converter={StaticResource RoleToVisibilityConverter}, ConverterParameter=!Admin}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="3" Background="White" Padding="16,12" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <TextBlock Text="Mercedes-Benz — лучшее для лучших" Foreground="#666" HorizontalAlignment="Center" FontSize="12"/>
        </Border>
    </Grid>
</Page>